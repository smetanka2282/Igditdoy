import pygame
import random
import sys
import urllib.request
import io

# --- Инициализация игры и звука ---
pygame.mixer.pre_init(44100, -16, 2, 512)
pygame.init()

# Настройки окна
WIDTH = 400
HEIGHT = 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Flappy Bird - 9А Яковлев Матвей")
clock = pygame.time.Clock()

# Шрифты для текста
game_font = pygame.font.SysFont("arial", 28, bold=True)

# Физика и переменные игры
gravity = 0.25
bird_movement = 0
game_active = False
score = 0

# --- Пути к файлам ---
BIRD_PATH = r"C:\игра 9А Яковлев Матвей\assets\img\bird.png"
BG_PATH = r"C:\игра 9А Яковлев Матвей\assets\img\Bg.png"
SCORE_SOUND_PATH = r"C:\игра 9А Яковлев Матвей\assets\score.wav"
# Ссылка на трубу с прозрачным фоном
PIPE_URL = "[attachment_0](attachment)"

# --- Загрузка графики ---
# 1. Птичка
try:
    bird_surface = pygame.image.load(BIRD_PATH).convert_alpha()
    bird_surface = pygame.transform.scale(bird_surface, (40, 30))
except FileNotFoundError:
    bird_surface = pygame.Surface((40, 30))
    bird_surface.fill((255, 255, 0))

bird_rect = bird_surface.get_rect(center=(100, HEIGHT // 2))

# 2. Фон
try:
    bg_surface = pygame.image.load(BG_PATH).convert()
    bg_surface = pygame.transform.scale(bg_surface, (WIDTH, HEIGHT))
except FileNotFoundError:
    bg_surface = pygame.Surface((WIDTH, HEIGHT))
    bg_surface.fill((135, 206, 235))

# 3. Трубы (загружаем по ссылке)
try:
    print("Загрузка трубы из интернета...")
    req = urllib.request.Request(PIPE_URL, headers={'User-Agent': 'Mozilla/5.0'})
    response = urllib.request.urlopen(req)
    pipe_file = io.BytesIO(response.read())
    
    pipe_bottom_surface = pygame.image.load(pipe_file).convert_alpha()
    pipe_bottom_surface = pygame.transform.scale(pipe_bottom_surface, (60, 450))
    print("Труба успешно загружена!")
except Exception as e:
    print(f"ВНИМАНИЕ: Не удалось загрузить трубу по ссылке: {e}")
    pipe_bottom_surface = pygame.Surface((60, 450))
    pipe_bottom_surface.fill((34, 139, 34))

# Переворачиваем картинку нижней трубы по вертикали, чтобы получить верхнюю
pipe_top_surface = pygame.transform.flip(pipe_bottom_surface, False, True)

pipe_list = []
SPAWNPIPE = pygame.USEREVENT
pygame.time.set_timer(SPAWNPIPE, 1500)
pipe_heights = [250, 300, 350, 400, 450]

# --- Загрузка звука ---
try:
    score_sound = pygame.mixer.Sound(SCORE_SOUND_PATH)
except FileNotFoundError:
    score_sound = None

def create_pipe():
    random_pipe_pos = random.choice(pipe_heights)
    bottom_pipe = pipe_bottom_surface.get_rect(midtop=(WIDTH + 50, random_pipe_pos))
    top_pipe = pipe_top_surface.get_rect(midbottom=(WIDTH + 50, random_pipe_pos - 150))
    return bottom_pipe, top_pipe

def move_pipes(pipes):
    for pipe in pipes:
        pipe.centerx -= 3
    return [pipe for pipe in pipes if pipe.right > -50]

def draw_pipes(pipes):
    for pipe in pipes:
        if pipe.bottom >= HEIGHT: 
            screen.blit(pipe_bottom_surface, pipe)
        else: 
            screen.blit(pipe_top_surface, pipe)

def check_collision(pipes):
    for pipe in pipes:
        if bird_rect.colliderect(pipe):
            return False
    if bird_rect.top <= -50 or bird_rect.bottom >= HEIGHT:
        return False
    return True

# --- Главный игровой цикл ---
while True:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()
        
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_SPACE and game_active:
                bird_movement = 0
                bird_movement -= 6 
            
            if event.key == pygame.K_SPACE and not game_active:
                game_active = True
                pipe_list.clear()
                bird_rect.center = (100, HEIGHT // 2)
                bird_movement = 0
                score = 0

        if event.type == SPAWNPIPE and game_active:
            pipe_list.extend(create_pipe())

    screen.blit(bg_surface, (0, 0))

    if game_active:
        bird_movement += gravity
        bird_rect.centery += int(bird_movement)
        screen.blit(bird_surface, bird_rect)
        
        pipe_list = move_pipes(pipe_list)
        draw_pipes(pipe_list)
        
        game_active = check_collision(pipe_list)

        for pipe in pipe_list:
            if pipe.bottom >= HEIGHT: 
                if pipe.centerx - 3 < bird_rect.centerx <= pipe.centerx:
                    score += 1
                    if score_sound:
                        score_sound.play()
        
        score_text = game_font.render(f"{int(score)}", True, (255, 255, 255))
        screen.blit(score_text, score_text.get_rect(center=(WIDTH // 2, 50)))
    else:
        game_over_text1 = game_font.render("FLAPPY BIRD", True, (255, 255, 0))
        game_over_text2 = game_font.render("Нажми ПРОБЕЛ", True, (255, 255, 255))
        screen.blit(game_over_text1, game_over_text1.get_rect(center=(WIDTH // 2, HEIGHT // 2 - 30)))
        screen.blit(game_over_text2, game_over_text2.get_rect(center=(WIDTH // 2, HEIGHT // 2 + 20)))
        
        if score > 0:
            score_res = game_font.render(f"Счет: {int(score)}", True, (255, 100, 100))
            screen.blit(score_res, score_res.get_rect(center=(WIDTH // 2, HEIGHT // 2 + 70)))

    pygame.display.update()
    clock.tick(120)
