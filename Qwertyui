import pygame
import sys

# Настройки окна
WIDTH, HEIGHT = 800, 450
FPS = 60

# Цвета
BG_COLOR = (20, 20, 35)      # Темно-синий фон
GROUND_COLOR = (40, 40, 60)  # Цвет пола
PLAYER_COLOR = (0, 255, 200) # Бирюзовый куб

class Game:
    def __init__(self):
        pygame.init()
        self.screen = pygame.display.set_mode((WIDTH, HEIGHT))
        pygame.display.set_caption("Geometry Dash 9A")
        self.clock = pygame.time.Clock()
        self.font = pygame.font.SysFont("Verdana", 24, bold=True)
        
        # Игрок
        self.player_size = 40
        self.player_rect = pygame.Rect(150, HEIGHT - 100, self.player_size, self.player_size)
        self.vel_y = 0
        self.gravity = 0.9
        self.jump_power = -14
        self.angle = 0  # Для вращения
        
        # Препятствия
        self.obstacle_width = 35
        self.obstacle_height = 45
        self.obstacles = []
        self.spawn_timer = 0
        
        self.score = 0
        self.game_active = True

    def reset_game(self):
        self.player_rect.y = HEIGHT - 100
        self.vel_y = 0
        self.obstacles = []
        self.score = 0
        self.angle = 0
        self.game_active = True

    def spawn_obstacle(self):
        # Создаем треугольное препятствие (шип) за краем экрана
        obs = pygame.Rect(WIDTH + 50, HEIGHT - 90, self.obstacle_width, self.obstacle_height)
        self.obstacles.append(obs)

    def draw_player(self):
        # Эффект вращения: создаем поверхность, крутим её и рисуем
        player_surface = pygame.Surface((self.player_size, self.player_size), pygame.SRCALPHA)
        pygame.draw.rect(player_surface, PLAYER_COLOR, (0, 0, self.player_size, self.player_size))
        pygame.draw.rect(player_surface, (255, 255, 255), (0, 0, self.player_size, self.player_size), 3) # Рамка
        
        rotated_surface = pygame.transform.rotate(player_surface, self.angle)
        new_rect = rotated_surface.get_rect(center=self.player_rect.center)
        self.screen.blit(rotated_surface, new_rect)

    def run(self):
        while True:
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    pygame.quit()
                    sys.exit()
                
                if event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_SPACE:
                        if self.game_active:
                            if self.player_rect.bottom >= HEIGHT - 50:
                                self.vel_y = self.jump_power
                        else:
                            self.reset_game()

            if self.game_active:
                # Гравитация и движение
                self.vel_y += self.gravity
                self.player_rect.y += self.vel_y
                
                # Ограничение по полу
                if self.player_rect.bottom > HEIGHT - 50:
                    self.player_rect.bottom = HEIGHT - 50
                    self.vel_y = 0
                    # Выравниваем угол при приземлении к ближайшим 90 градусам
                    self.angle = (self.angle // 90) * 90
                else:
                    # Вращаем куб в воздухе
                    self.angle -= 5 

                # Отрисовка
                self.screen.fill(BG_COLOR)
                pygame.draw.rect(self.screen, GROUND_COLOR, (0, HEIGHT - 50, WIDTH, 50))
                pygame.draw.line(self.screen, (100, 100, 150), (0, HEIGHT - 50), (WIDTH, HEIGHT - 50), 4)

                # Управление препятствиями
                self.spawn_timer += 1
                if self.spawn_timer > 70: # Интервал появления
                    self.spawn_obstacle()
                    self.spawn_timer = 0

                for obs in self.obstacles[:]:
                    obs.x -= 8 # Скорость движения уровня
                    # Рисуем шип
                    pygame.draw.polygon(self.screen, (255, 60, 60), [
                        (obs.left, obs.bottom),
                        (obs.centerx, obs.top),
                        (obs.right, obs.bottom)
                    ])
                    
                    # Проверка столкновений
                    if self.player_rect.colliderect(obs):
                        self.game_active = False

                    if obs.right < 0:
                        self.obstacles.remove(obs)
                        self.score += 1

                self.draw_player()
                
                # Счет
                score_surf = self.font.render(f"SCORE: {self.score}", True, (255, 255, 255))
                self.screen.blit(score_surf, (20, 20))
            else:
                # Экран проигрыша
                over_surf = self.font.render("GAME OVER - PRESS SPACE TO RESTART", True, (255, 255, 255))
                self.screen.blit(over_surf, (WIDTH // 2 - 200, HEIGHT // 2))

            pygame.display.flip()
            self.clock.tick(FPS)

if __name__ == "__main__":
    Game().run()
