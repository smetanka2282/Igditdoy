import pygame
import sys
import random
import os

# --- Инициализация ---
pygame.init()

SCREEN_WIDTH, SCREEN_HEIGHT = 400, 600
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
clock = pygame.time.Clock()
pygame.display.set_caption('Flappy Bird - Clean Version')

# Константы
WHITE = (255, 255, 255)
BLUE = (113, 197, 207)
GREEN = (34, 139, 34)
YELLOW = (255, 255, 0)
RED = (255, 0, 0)

font = pygame.font.SysFont('Arial', 40, bold=True)
small_font = pygame.font.SysFont('Arial', 20)

# Путь к картинке птицы
base_path = os.path.dirname(os.path.abspath(__file__))
bird_path = os.path.join(base_path, 'bird.png')

# Загрузка птицы или создание желтого квадрата, если файла нет
if os.path.exists(bird_path):
    bird_surface = pygame.transform.scale(pygame.image.load(bird_path).convert_alpha(), (34, 24))
else:
    bird_surface = pygame.Surface((34, 24))
    bird_surface.fill(YELLOW)

# Вместо текстур труб и фона создаем просто цветные поверхности
bg_surface = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
bg_surface.fill(BLUE)

pipe_surface = pygame.Surface((60, 450))
pipe_surface.fill(GREEN)
pipe_top_surface = pipe_surface # Для цвета верх и низ одинаковые

# Состояние игры
bird_rect = bird_surface.get_rect(center=(50, 300))
bird_movement = 0
gravity = 0.25
game_active = False
score = 0
high_score = 0
pipe_list = []

SPAWNPIPE = pygame.USEREVENT
pygame.time.set_timer(SPAWNPIPE, 1500)

def create_pipe():
    pos = random.choice([200, 300, 400])
    gap = 150
    bottom = pipe_surface.get_rect(midtop=(450, pos + gap//2))
    top = pipe_top_surface.get_rect(midbottom=(450, pos - gap//2))
    return {"rect": bottom, "passed": False}, {"rect": top, "passed": False}

while True:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()
        
        if event.type == pygame.KEYDOWN and event.key == pygame.K_SPACE:
            if game_active:
                bird_movement = -6.5
            else:
                game_active = True
                pipe_list.clear()
                bird_rect.center = (50, 300)
                bird_movement = 0
                score = 0

        if event.type == SPAWNPIPE and game_active:
            pipe_list.extend(create_pipe())

    screen.blit(bg_surface, (0, 0))

    if game_active:
        bird_movement += gravity
        bird_rect.centery += bird_movement
        screen.blit(bird_surface, bird_rect)
        
        for pipe_item in pipe_list:
            pipe = pipe_item["rect"]
            pipe.centerx -= 4
            screen.blit(pipe_surface, pipe)
            
            if bird_rect.colliderect(pipe):
                game_active = False
            
            if not pipe_item["passed"] and bird_rect.left > pipe.right:
                pipe_item["passed"] = True
                score += 0.5

        pipe_list = [p for p in pipe_list if p["rect"].right > -50]

        if bird_rect.top <= -50 or bird_rect.bottom >= SCREEN_HEIGHT:
            game_active = False

        score_text = font.render(str(int(score)), True, WHITE)
        screen.blit(score_text, (SCREEN_WIDTH//2 - 10, 50))
    else:
        if score > high_score: high_score = score
        overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT), pygame.SRCALPHA)
        overlay.fill((0, 0, 0, 150))
        screen.blit(overlay, (0, 0))
        
        over_text = font.render("GAME OVER", True, RED)
        best_text = font.render(f"BEST: {int(high_score)}", True, WHITE)
        restart_text = small_font.render("PRESS SPACE", True, WHITE)
        
        screen.blit(over_text, over_text.get_rect(center=(200, 250)))
        screen.blit(best_text, best_text.get_rect(center=(200, 320)))
        screen.blit(restart_text, restart_text.get_rect(center=(200, 400)))

    pygame.display.update()
    clock.tick(60)
