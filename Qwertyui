import pygame
import sys
import random
import os

# Инициализация звука и графики
pygame.mixer.pre_init(frequency=44100, size=-16, channels=2, buffer=512)
pygame.init()

# Настройки окна
SCREEN_WIDTH, SCREEN_HEIGHT = 400, 600
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
clock = pygame.time.Clock()
pygame.display.set_caption('Flappy Bird: Minimalist Edition')

# Переменные
gravity = 0.25
bird_movement = 0
game_active = False
score = 0
high_score = 0
WHITE = (255, 255, 255)
font = pygame.font.SysFont('Arial', 32, bold=True)

# Путь к файлам
base_path = os.path.dirname(__file__)

# --- ЗАГРУЗКА РЕСУРСОВ ---
try:
    # Текстуры
    bg_surface = pygame.image.load(os.path.join(base_path, 'bg.png')).convert()
    bg_surface = pygame.transform.scale(bg_surface, (SCREEN_WIDTH, SCREEN_HEIGHT))
    
    bird_surface = pygame.image.load(os.path.join(base_path, 'bird.png')).convert_alpha()
    bird_rect = bird_surface.get_rect(center=(50, 300))
    
    pipe_surface = pygame.image.load(os.path.join(base_path, 'pipe_bottom.png')).convert_alpha()
    pipe_bottom = pygame.transform.scale(pipe_surface, (60, 450))
    pipe_top = pygame.transform.flip(pipe_bottom, False, True)
    
    # Только один звук — звук очка/пролёта
    score_sound = pygame.mixer.Sound(os.path.join(base_path, 'score.wav'))
except Exception as e:
    print(f"Ошибка: проверь наличие файлов bg.png, bird.png, pipe_bottom.png и score.wav\n{e}")
    pygame.quit()
    sys.exit()

# --- ЛОГИКА ТРУБ ---
pipe_list = []
SPAWNPIPE = pygame.USEREVENT
pygame.time.set_timer(SPAWNPIPE, 1400)

def create_pipe():
    random_pos = random.choice([200, 300, 400])
    gap = 160 # Размер прохода
    bottom_p = pipe_bottom.get_rect(midtop=(500, random_pos + gap//2))
    top_p = pipe_top.get_rect(midbottom=(500, random_pos - gap//2))
    return bottom_p, top_p

def move_pipes(pipes):
    for pipe in pipes:
        pipe.centerx -= 4
    return [pipe for pipe in pipes if pipe.right > -50]

def draw_pipes(pipes):
    for pipe in pipes:
        if pipe.bottom >= SCREEN_HEIGHT:
            screen.blit(pipe_bottom, pipe)
        else:
            screen.blit(pipe_top, pipe)

# --- ГЛАВНЫЙ ЦИКЛ ---
while True:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()
        
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_SPACE:
                if game_active:
                    bird_movement = 0
                    bird_movement -= 7
                else:
                    # Рестарт игры
                    game_active, score = True, 0
                    pipe_list.clear()
                    bird_rect.center, bird_movement = (50, 300), 0

        if event.type == SPAWNPIPE and game_active:
            pipe_list.extend(create_pipe())

    # Фон всегда на заднем плане
    screen.blit(bg_surface, (0, 0))

    if game_active:
        # Птица
        bird_movement += gravity
        bird_rect.centery += bird_movement
        screen.blit(bird_surface, bird_rect)
        
        # Трубы
        pipe_list = move_pipes(pipe_list)
        draw_pipes(pipe_list)
        
        # Столкновения
        for pipe in pipe_list:
            if bird_rect.colliderect(pipe):
                game_active = False
        if bird_rect.top <= -50 or bird_rect.bottom >= 600:
            game_active = False
            
        # Счёт и Звук пролёта
        for pipe in pipe_list:
            if 48 < pipe.centerx < 52:
                score += 0.5
                if score % 1 == 0:
                    score_sound.play() # ВОТ ОН, ТОТ САМЫЙ ЗВУК
        
        # Отображение счёта
        score_surf = font.render(str(int(score)), True, WHITE)
        screen.blit(score_surf, (190, 50))
    else:
        # Экран проигрыша / ожидания
        if score > high_score: high_score = score
        res_surf = font.render(f'BEST: {int(high_score)}', True, WHITE)
        screen.blit(res_surf, res_surf.get_rect(center=(200, 300)))
        msg = font.render('PRESS SPACE', True, WHITE)
        screen.blit(msg, msg.get_rect(center=(200, 450)))

    pygame.display.update()
    clock.tick(60)

