import pygame
import sys
import random
import os

# Настройка путей (учитывая твою структуру папок)
# Мы поднимаемся на уровень выше из папки с кодом и заходим в assets/img
BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
IMAGE_PATH = os.path.join(BASE_DIR, 'assets', 'img', 'bird.png')

# Инициализация Pygame
pygame.init()

# Константы
SCREEN_WIDTH = 400
SCREEN_HEIGHT = 600
GRAVITY = 0.25
BIRD_JUMP = -6
PIPE_SPEED = 3
WHITE = (255, 255, 255)
SKY_BLUE = (113, 197, 207)

screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
clock = pygame.time.Clock()
font = pygame.font.SysFont("Arial", 32)

# Загрузка изображения птички
try:
    bird_surface = pygame.image.load(IMAGE_PATH).convert_alpha()
    bird_surface = pygame.transform.scale(bird_surface, (45, 35)) # Подгоняем размер
except FileNotFoundError:
    print(f"Не удалось найти файл по пути: {IMAGE_PATH}")
    # Создаем временный квадрат, если картинка не найдена
    bird_surface = pygame.Surface((40, 30))
    bird_surface.fill((255, 200, 0))

bird_rect = bird_surface.get_rect(center = (100, SCREEN_HEIGHT // 2))

# Переменные игры
bird_movement = 0
score = 0
game_active = True

# Трубы
pipe_list = []
SPAWNPIPE = pygame.USEREVENT
pygame.time.set_timer(SPAWNPIPE, 1200)

def create_pipe():
    random_pipe_pos = random.randint(200, 500)
    bottom_pipe = bird_surface.get_rect(midtop = (500, random_pipe_pos)) # Используем rect для логики
    # Для простоты рисуем трубы программно, так как картинок для них нет в ТЗ
    return bottom_pipe

def move_pipes(pipes):
    for pipe in pipes:
        pipe.centerx -= PIPE_SPEED
    return [pipe for pipe in pipes if pipe.right > 0]

def draw_pipes(pipes):
    for pipe in pipes:
        # Рисуем нижнюю трубу
        pygame.draw.rect(screen, (75, 180, 70), pipe)
        # Рисуем верхнюю трубу (с просветом 150 пикселей)
        top_pipe_rect = pygame.Rect(pipe.left, pipe.top - 150 - 500, 50, 500)
        pygame.draw.rect(screen, (75, 180, 70), top_pipe_rect)

def check_collision(pipes):
    for pipe in pipes:
        if bird_rect.colliderect(pipe) or bird_rect.colliderect(pygame.Rect(pipe.left, pipe.top - 150 - 500, 50, 500)):
            return False
    if bird_rect.top <= -100 or bird_rect.bottom >= SCREEN_HEIGHT:
        return False
    return True

# Главный цикл игры
while True:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()
        
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_SPACE and game_active:
                bird_movement = 0
                bird_movement += BIRD_JUMP
            
            if event.key == pygame.K_SPACE and not game_active:
                # Рестарт игры
                game_active = True
                pipe_list.clear()
                bird_rect.center = (100, SCREEN_HEIGHT // 2)
                bird_movement = 0
                score = 0

        if event.type == SPAWNPIPE:
            pipe_list.append(create_pipe())

    screen.fill(SKY_BLUE)

    if game_active:
        # Птица
        bird_movement += GRAVITY
        bird_rect.centery += bird_movement
        screen.blit(bird_surface, bird_rect)
        
        # Трубы
        pipe_list = move_pipes(pipe_list)
        draw_pipes(pipe_list)
        
        # Проверка столкновений
        game_active = check_collision(pipe_list)
        
        # Счет (упрощенно: за каждую выжившую итерацию, деленную на FPS)
        score += 0.01
        score_surface = font.render(f'Score: {int(score)}', True, WHITE)
        screen.blit(score_surface, (10, 10))
    else:
        msg = font.render("GAME OVER (Space to Restart)", True, (200, 0, 0))
        screen.blit(msg, (30, SCREEN_HEIGHT // 2))

    pygame.display.update()
    clock.tick(60)
