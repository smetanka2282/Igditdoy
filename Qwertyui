import pygame
import sys
import random
import os

# 1. Настройка звукового буфера (чтобы звук не опаздывал)
pygame.mixer.pre_init(frequency=44100, size=-16, channels=2, buffer=512)
pygame.init()

# Настройки экрана
SCREEN_WIDTH = 400
SCREEN_HEIGHT = 600
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
clock = pygame.time.Clock()
pygame.display.set_caption('Flappy Bird: Full Version')

# Переменные и шрифты
WHITE = (255, 255, 255)
font = pygame.font.SysFont('Arial', 35, bold=True)
small_font = pygame.font.SysFont('Arial', 22, bold=True)
gravity = 0.25
bird_movement = 0
game_active = False
score = 0
high_score = 0

# Путь к папке со скриптом
base_path = os.path.dirname(__file__)

# --- ЗАГРУЗКА РЕСУРСОВ ---
def load_assets():
    try:
        # Текстуры
        bg = pygame.image.load(os.path.join(base_path, 'bg.png')).convert()
        bg = pygame.transform.scale(bg, (SCREEN_WIDTH, SCREEN_HEIGHT))
        
        bird = pygame.image.load(os.path.join(base_path, 'bird.png')).convert_alpha()
        
        p_bottom = pygame.image.load(os.path.join(base_path, 'pipe_bottom.png')).convert_alpha()
        p_bottom = pygame.transform.scale(p_bottom, (60, 450))
        p_top = pygame.transform.flip(p_bottom, False, True)
        
        # Звуки
        s_flap = pygame.mixer.Sound(os.path.join(base_path, 'flap.wav'))
        s_hit = pygame.mixer.Sound(os.path.join(base_path, 'hit.wav'))
        s_score = pygame.mixer.Sound(os.path.join(base_path, 'point.wav'))
        
        return bg, bird, p_bottom, p_top, s_flap, s_hit, s_score
    except Exception as e:
        print(f"Ошибка загрузки файлов: {e}")
        pygame.quit()
        sys.exit()

bg_surface, bird_surface, pipe_bottom, pipe_top, flap_sound, hit_sound, score_sound = load_assets()
bird_rect = bird_surface.get_rect(center=(50, 300))

# --- ЛОГИКА ТРУБ ---
pipe_list = []
SPAWNPIPE = pygame.USEREVENT
pygame.time.set_timer(SPAWNPIPE, 1400)
pipe_heights = [200, 300, 400]

def create_pipe():
    random_pos = random.choice(pipe_heights)
    bottom_p = pipe_bottom.get_rect(midtop=(500, random_pos + 80))
    top_p = pipe_top.get_rect(midbottom=(500, random_pos - 80))
    return bottom_p, top_p

def move_pipes(pipes):
    for pipe in pipes:
        pipe.centerx -= 4
    return [pipe for pipe in pipes if pipe.right > -50]

def draw_pipes(pipes):
    for pipe in pipes:
        if pipe.bottom >= 600:
            screen.blit(pipe_bottom, pipe)
        else:
            screen.blit(pipe_top, pipe)

# --- ПРОВЕРКИ ---
def check_collision(pipes):
    for pipe in pipes:
        if bird_rect.colliderect(pipe):
            hit_sound.play()
            return False
    if bird_rect.top <= -50 or bird_rect.bottom >= 600:
        hit_sound.play()
        return False
    return True

def update_score(pipes):
    global score
    for pipe in pipes:
        if 48 < pipe.centerx < 52:
            score += 0.5
            if score % 1 == 0:
                score_sound.play()

def display_score(status):
    if status == 'playing':
        surf = font.render(str(int(score)), True, WHITE)
        screen.blit(surf, surf.get_rect(center=(200, 50)))
    else:
        s_surf = font.render(f'SCORE: {int(score)}', True, WHITE)
        screen.blit(s_surf, s_surf.get_rect(center=(200, 180)))
        h_surf = font.render(f'BEST: {int(high_score)}', True, WHITE)
        screen.blit(h_surf, h_surf.get_rect(center=(200, 250)))

# --- ГЛАВНЫЙ ЦИКЛ ---
while True:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()
        
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_SPACE:
                if game_active:
                    bird_movement = 0
                    bird_movement -= 7
                    flap_sound.play()
                else:
                    # Рестарт
                    game_active = True
                    pipe_list.clear()
                    bird_rect.center = (50, 300)
                    bird_movement = 0
                    score = 0

        if event.type == SPAWNPIPE and game_active:
            pipe_list.extend(create_pipe())

    # Отрисовка
    screen.blit(bg_surface, (0, 0))

    if game_active:
        # Птица
        bird_movement += gravity
        bird_rect.centery += bird_movement
        screen.blit(bird_surface, bird_rect)
        
        # Трубы
        pipe_list = move_pipes(pipe_list)
        draw_pipes(pipe_list)
        
        # Состояние
        game_active = check_collision(pipe_list)
        update_score(pipe_list)
        display_score('playing')
    else:
        if score > high_score: high_score = score
        display_score('game_over')
        
        msg = "PRESS SPACE TO START" if score == 0 else "GAME OVER! SPACE TO RESTART"
        msg_surf = small_font.render(msg, True, WHITE)
        screen.blit(msg_surf, msg_surf.get_rect(center=(200, 450)))

    pygame.display.update()
    clock.tick(60)
