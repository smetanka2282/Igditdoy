import pygame
import sys
import os
import random

# Инициализация Pygame
pygame.init()

# Настройки окна
SCREEN_WIDTH = 400
SCREEN_HEIGHT = 600
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
pygame.display.set_caption("FleppiBerts")

# Настройка путей (выход из папки с кодом и переход в assets/img)
# Мы используем os.path.join для совместимости путей
BASE_DIR = os.path.dirname(os.path.dirname(__file__))
IMAGE_PATH = os.path.join(BASE_DIR, 'assets', 'img', 'bird.png')

# Цвета
WHITE = (255, 255, 255)
BLUE = (135, 206, 235)
GREEN = (34, 139, 34)

# Игровые переменные
gravity = 0.25
bird_movement = 0
game_active = True
score = 0

# Загрузка птички
try:
    bird_surface = pygame.image.load(IMAGE_PATH).convert_alpha()
    # Если картинка слишком большая, можно изменить её размер:
    bird_surface = pygame.transform.scale(bird_surface, (50, 35))
except FileNotFoundError:
    print(f"Не удалось найти файл по пути: {IMAGE_PATH}")
    # Создаем временный прямоугольник, если файл не найден
    bird_surface = pygame.Surface((50, 35))
    bird_surface.fill((255, 0, 0))

bird_rect = bird_surface.get_rect(center=(100, SCREEN_HEIGHT // 2))

# Препятствия (Трубы)
pipe_list = []
SPAWNPIPE = pygame.USEREVENT
pygame.time.set_timer(SPAWNPIPE, 1200)
pipe_height = [300, 400, 500]

def create_pipe():
    random_pipe_pos = random.choice(pipe_height)
    bottom_pipe = bird_surface.get_rect(midtop=(500, random_pipe_pos)) # Временно используем размеры для логики
    # Создаем прямоугольники для труб
    top_pipe = pygame.Rect(500, random_pipe_pos - 650, 50, 500)
    bottom_pipe = pygame.Rect(500, random_pipe_pos, 50, 500)
    return tp_pipe, bottom_pipe # Ошибка в названии, поправлю ниже в цикле

def move_pipes(pipes):
    for pipe in pipes:
        pipe.centerx -= 5
    return [pipe for pipe in pipes if pipe.right > -50]

def draw_pipes(pipes):
    for pipe in pipes:
        pygame.draw.rect(screen, GREEN, pipe)

def check_collision(pipes):
    for pipe in pipes:
        if bird_rect.colliderect(pipe):
            return False
    if bird_rect.top <= -100 or bird_rect.bottom >= SCREEN_HEIGHT:
        return False
    return True

# Таймер
clock = pygame.time.Clock()

# Главный цикл игры
while True:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()
        
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_SPACE and game_active:
                bird_movement = 0
                bird_movement -= 8
            if event.key == pygame.K_SPACE and not game_active:
                game_active = True
                pipe_list.clear()
                bird_rect.center = (100, SCREEN_HEIGHT // 2)
                bird_movement = 0
                score = 0

        if event.type == SPAWNPIPE:
            random_pos = random.choice(pipe_height)
            pipe_list.append(pygame.Rect(450, random_pos, 60, 500))         # Нижняя
            pipe_list.append(pygame.Rect(450, random_pos - 650, 60, 500))   # Верхняя

    # Отрисовка фона
    screen.fill(BLUE)

    if game_active:
        # Птичка
        bird_movement += gravity
        bird_rect.centery += bird_movement
        screen.blit(bird_surface, bird_rect)
        
        game_active = check_collision(pipe_list)

        # Трубы
        pipe_list = move_pipes(pipe_list)
        draw_pipes(pipe_list)
        
        score += 0.01 # Примерный подсчет очков
    else:
        # Экран проигрыша
        font = pygame.font.SysFont('Arial', 32)
        text = font.render("Нажми ПРОБЕЛ, чтобы начать", True, WHITE)
        screen.blit(text, (30, SCREEN_HEIGHT // 2))

    pygame.display.update()
    clock.tick(60)
